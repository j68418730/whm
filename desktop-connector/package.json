{
  "name": "planet-hosts-studio",
  "version": "1.0.0",
  "description": "Planet Hosts Studio Desktop - Full broadcast software like SAM Broadcaster",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dist": "electron-builder --win --x64 --publish never"
  },
  "build": {
    "appId": "com.planethosts.studio",
    "productName": "Planet Hosts Studio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "database.js",
      "renderer/**/*",
      "config/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "renderer/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "extraResources": [
      {
        "from": "ffmpeg/",
        "to": "ffmpeg/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "music-metadata": "^11.13.0",
    "musicmetadata": "^2.0.5",
    "node-id3": "^0.2.9",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
