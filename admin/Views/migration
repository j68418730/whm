<table style="width:100%;border-collapse:collapse;font-size:12px">
<thead><tr><th style="text-align:left;padding:4px 8px;border-bottom:1px solid var(--border-color)">Source Package</th>
<th style="text-align:left;padding:4px 8px;border-bottom:1px solid var(--border-color)">Local Package</th></tr></thead>
<tbody id="packageMapRows">
</tbody>
</table>
</div>
<button type="submit" class="btn primary">Start Migration</button>
</form></div></div>

<script>
(function() {
    var jobId = <?php echo $jobId; ?>;
    fetch('/admin/migration/get-preflight?job=' + jobId)
    .then(function(r) { return r.json(); })
    .then(function(d) {
        var html = '';
        if (d.preflight && d.preflight.connected) {
            html += '<div style="color:#4ade80;font-weight:600">Connected successfully</div>';
            html += '<div style="margin-top:8px"><strong>Accounts found:</strong> ' + (d.preflight.accounts ? d.preflight.accounts.length : 0) + '</div>';
            if (d.preflight.server_info) {
                html += '<div style="margin-top:4px"><strong>Server Info:</strong> ' + JSON.stringify(d.preflight.server_info) + '</div>';
            }
            if (d.preflight.accounts && d.preflight.accounts.length > 0) {
                html += '<div style="margin-top:8px;font-size:11px"><strong>Accounts:</strong><ul>';
                d.preflight.accounts.slice(0, 10).forEach(function(a) {
                    html += '<li>' + (a.username || '?') + ' (' + (a.domain || 'no domain') + ') - ' + (a.plan || 'no plan') + '</li>';
                });
                if (d.preflight.accounts.length > 10) html += '<li>... and ' + (d.preflight.accounts.length - 10) + ' more</li>';
                html += '</ul></div>';
            }
            // Build package map
            var localPkgs = <?php echo json_encode(array_map(function($p) { return $p->name ?? $p->id ?? ''; }, $localPackages)); ?>;
            var pkgMapHtml = '<tr><td colspan="2" style="padding:4px 8px;color:#64748b">No source packages detected</td></tr>';
            if (d.preflight.accounts) {
                var pkgs = {};
                d.preflight.accounts.forEach(function(a) { if (a.plan) pkgs[a.plan] = true; });
                var pkgNames = Object.keys(pkgs);
                if (pkgNames.length > 0) {
                    pkgMapHtml = '';
                    pkgNames.forEach(function(p) {
                        pkgMapHtml += '<tr><td style="padding:4px 8px;border-bottom:1px solid var(--border-color)">' + p + '</td>';
                        pkgMapHtml += '<td style="padding:4px 8px;border-bottom:1px solid var(--border-color)"><select name="package_map[' + p + ']">';
                        pkgMapHtml += '<option value="">-- Keep as-is --</option>';
                        localPkgs.forEach(function(lp) {
                            pkgMapHtml += '<option value="' + lp + '">' + lp + '</option>';
                        });
                        pkgMapHtml += '</select></td></tr>';
                    });
                }
            }
            document.getElementById('packageMapRows').innerHTML = pkgMapHtml;
        } else if (d.preflight) {
            html += '<div style="color:#f87171;font-weight:600">Connection failed</div>';
            if (d.preflight.errors) html += '<div style="margin-top:4px;color:#f87171">' + d.preflight.errors.join(', ') + '</div>';
        } else {
            html += '<div style="color:#fbbf24">No pre-flight data available.</div>';
        }
        document.getElementById('preflightResults').innerHTML = html;
    }).catch(function(e) {
        document.getElementById('preflightResults').innerHTML = '<div style="color:#f87171">Error loading pre-flight data: ' + e.message + '</div>';
    });
})();
</script>
