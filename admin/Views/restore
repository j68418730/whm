<script>
function previewBackup(filename, btn) {
    var el = btn.parentElement.parentElement.querySelector('.preview-content');
    if (el.style.display !== 'none') { el.style.display = 'none'; return; }
    el.style.display = 'block';
    var pre = el.querySelector('pre');
    fetch('/admin/restore/preview?file=' + encodeURIComponent(filename))
    .then(function(r) { return r.json(); })
    .then(function(d) {
        if (d.error) { pre.textContent = 'Error: ' + d.error; return; }
        var html = 'Total files: ' + (d.total_files || 0) + '\n';
        html += 'Total size: ' + (d.total_size || 'N/A') + '\n\n';
        if (d.dirs && d.dirs.length) {
            html += 'Directories:\n' + d.dirs.slice(0, 30).join('\n');
            if (d.dirs.length > 30) html += '\n... and ' + (d.dirs.length - 30) + ' more';
        }
        if (d.files && d.files.length) {
            html += '\n\nFiles (first 50):\n' + d.files.slice(0, 50).join('\n');
            if (d.files.length > 50) html += '\n... and ' + (d.files.length - 50) + ' more';
        }
        pre.textContent = html;
    }).catch(function(e) { pre.textContent = 'Error fetching preview: ' + e.message; });
}
</script>